# GEMINI_API_KEY: Required for Gemini AI API calls and Google Veo 3.1 video generation.
# Get your API key from https://aistudio.google.com/app/apikey
# NOTE: Veo 3.1 access requires a Gemini API key with Veo model enabled.
# Without this key, Realistic Video Mode will fall back to Replicate/Luma.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# REPLICATE_API_KEY: Fallback for video generation when Veo 3.1 fails.
# Get your API key from https://replicate.com/account/api-tokens
# Used as 2nd fallback after Veo (after Veo fails, tries Replicate Luma Dream Machine)
REPLICATE_API_KEY="MY_REPLICATE_API_KEY"

# Optional: LUMA_API_KEY - Legacy support for Luma Dream Machine (deprecated)
# Use REPLICATE_API_KEY or GEMINI_API_KEY with Veo 3.1 support instead
# LUMA_API_KEY="MY_LUMA_API_KEY"
